install! 'cocoapods', :disable_input_output_paths => true

source 'https://github.com/CocoaPods/Specs.git'

# macOS target
target 'ZappaStream' do
  platform :osx, '14.0'
  use_frameworks!
  pod 'VLCKit', '~> 3.6.0'
end

# iOS target
target 'ZappaStream-iOS' do
  platform :ios, '17.5'
  use_frameworks!
  pod 'MobileVLCKit', '~> 3.6.0'
end
